.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.swp
*~

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Maven wrapper (can be regenerated)
.mvn/wrapper/maven-wrapper.jar

# Test files
test_*.py
test_*.wav
test_*.webm

# Large documents
*.docx
*.pdf

# Windows executables
*.exe
minio.exe
